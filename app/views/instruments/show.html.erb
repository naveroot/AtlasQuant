<% content_for :title, "#{@instrument.secid} — Atlas Quant" %>

<div class="w-full max-w-5xl mx-auto">
  <div class="mb-6">
    <%= link_to "← All instruments", instruments_path, class: "text-sm font-medium text-blue-600 hover:text-blue-700" %>
  </div>

  <div class="mb-8 flex flex-col gap-4 sm:flex-row sm:items-end sm:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @instrument.secid %></h1>
      <p class="mt-1 text-gray-600"><%= @instrument.shortname %> · <%= @instrument.asset_code %></p>
    </div>

    <%= form_with url: instrument_path(@instrument.secid), method: :get, local: true, class: "flex flex-wrap items-end gap-3" do |form| %>
      <div>
        <%= form.label :from, "From", class: "block text-xs font-medium text-gray-500 mb-1" %>
        <%= form.date_field :from, value: @from, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <div>
        <%= form.label :till, "Till", class: "block text-xs font-medium text-gray-500 mb-1" %>
        <%= form.date_field :till, value: @till, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
      </div>
      <%= form.submit "Update", class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 cursor-pointer" %>
    <% end %>
  </div>

  <% if @candles.any? %>
    <div class="rounded-xl border border-gray-200 bg-white p-6 shadow-sm">
      <h2 class="mb-4 text-lg font-semibold text-gray-900">Close price</h2>
      <div class="h-96">
        <canvas
          data-controller="price-chart"
          data-price-chart-labels-value="<%= @candles.map { |c| c.traded_at.strftime("%Y-%m-%d") }.to_json %>"
          data-price-chart-values-value="<%= @candles.map(&:close).to_json %>"
        ></canvas>
      </div>
    </div>

    <div class="mt-8 overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Date</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Open</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">High</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Low</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Close</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500">Volume</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @candles.reverse_each do |candle| %>
            <tr>
              <td class="px-6 py-3 text-sm text-gray-900"><%= candle.traded_at.strftime("%Y-%m-%d") %></td>
              <td class="px-6 py-3 text-right font-mono text-sm text-gray-700"><%= candle.open %></td>
              <td class="px-6 py-3 text-right font-mono text-sm text-gray-700"><%= candle.high %></td>
              <td class="px-6 py-3 text-right font-mono text-sm text-gray-700"><%= candle.low %></td>
              <td class="px-6 py-3 text-right font-mono text-sm font-medium text-gray-900"><%= candle.close %></td>
              <td class="px-6 py-3 text-right font-mono text-sm text-gray-500"><%= number_with_delimiter(candle.volume) %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-xl border border-amber-200 bg-amber-50 px-6 py-12 text-center text-amber-900">
      No candle data for the selected period.
    </div>
  <% end %>
</div>
