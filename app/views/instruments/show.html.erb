<% content_for :title, "#{@instrument.secid} — Atlas Quant" %>

<div class="w-full max-w-6xl mx-auto">
  <div class="mb-6">
    <%= link_to "← All instruments", instruments_path, class: "text-sm font-medium text-blue-600 hover:text-blue-700" %>
  </div>

  <div class="mb-6 flex flex-col gap-4 lg:flex-row lg:items-start lg:justify-between">
    <div>
      <h1 class="text-3xl font-bold text-gray-900"><%= @instrument.secid %></h1>
      <p class="mt-1 text-gray-600"><%= @instrument.shortname %> · <%= @instrument.asset_code %></p>
    </div>

    <div class="flex flex-wrap items-center gap-3">
      <% if logged_in? %>
        <% if @favorited %>
          <%= button_to "Remove from favorites",
                instrument_favorite_path(@instrument.secid),
                method: :delete,
                class: "rounded-lg border border-amber-300 bg-amber-50 px-4 py-2 text-sm font-medium text-amber-800 hover:bg-amber-100 cursor-pointer" %>
        <% else %>
          <%= button_to "Add to favorites",
                instrument_favorite_path(@instrument.secid),
                method: :post,
                class: "rounded-lg border border-blue-300 bg-blue-50 px-4 py-2 text-sm font-medium text-blue-800 hover:bg-blue-100 cursor-pointer" %>
        <% end %>
      <% end %>

      <div class="flex flex-wrap items-center gap-2">
      <% [ [ "7D", 7 ], [ "30D", 30 ], [ "90D", 90 ] ].each do |label, days| %>
        <% preset_from = Date.current - days.days %>
        <% preset_till = Date.current %>
        <% active = @from == preset_from && @till == preset_till %>
        <%= link_to label,
              instrument_path(@instrument.secid, from: preset_from, till: preset_till),
              class: "rounded-lg px-3 py-1.5 text-sm font-medium ring-1 ring-inset #{active ? 'bg-blue-600 text-white ring-blue-600' : 'bg-white text-gray-700 ring-gray-300 hover:bg-gray-50'}" %>
      <% end %>
      </div>
    </div>
  </div>

  <%= form_with url: instrument_path(@instrument.secid), method: :get, local: true, class: "mb-8 flex flex-wrap items-end gap-3 rounded-xl border border-gray-200 bg-white p-4 shadow-sm" do |form| %>
    <div>
      <%= form.label :from, "From", class: "block text-xs font-medium text-gray-500 mb-1" %>
      <%= form.date_field :from, value: @from, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= form.label :till, "Till", class: "block text-xs font-medium text-gray-500 mb-1" %>
      <%= form.date_field :till, value: @till, class: "rounded-lg border border-gray-300 px-3 py-2 text-sm" %>
    </div>
    <%= form.submit "Apply range", class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 cursor-pointer" %>
  <% end %>

  <% if @candles.any? %>
    <% summary = instrument_summary(@candles) %>

    <div class="mb-6 grid grid-cols-2 gap-4 lg:grid-cols-4">
      <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Last close</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900"><%= number_with_precision(summary[:last_close], precision: 2, delimiter: ",") %></p>
      </div>
      <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Change</p>
        <p class="mt-1 inline-flex items-center rounded-md px-2 py-1 text-sm font-semibold ring-1 ring-inset <%= change_badge_classes(summary[:change]) %>">
          <%= summary[:change].positive? ? "+" : "" %><%= number_with_precision(summary[:change], precision: 2) %>
          (<%= summary[:change_pct].positive? ? "+" : "" %><%= number_with_precision(summary[:change_pct], precision: 2) %>%)
        </p>
      </div>
      <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Range</p>
        <p class="mt-1 text-sm font-medium text-gray-900">
          <%= number_with_precision(summary[:low], precision: 2) %> — <%= number_with_precision(summary[:high], precision: 2) %>
        </p>
      </div>
      <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm">
        <p class="text-xs font-medium uppercase tracking-wide text-gray-500">Total volume</p>
        <p class="mt-1 text-2xl font-semibold text-gray-900"><%= number_with_delimiter(summary[:volume]) %></p>
      </div>
    </div>

    <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm sm:p-6">
      <div class="mb-4 flex items-center justify-between gap-4">
        <h2 class="text-lg font-semibold text-gray-900">Price chart</h2>
        <p class="text-xs text-gray-500"><%= @from %> — <%= @till %> · <%= pluralize(@candles.size, "candle") %></p>
      </div>

      <%= tag.div(
        class: "h-[28rem] w-full",
        data: {
          controller: "price-chart",
          price_chart_candles_value: candlestick_chart_data(@candles),
          price_chart_target: "container"
        }
      ) %>

      <p class="mt-4 text-center text-xs text-gray-400">
        Charts by <%= link_to "TradingView", "https://www.tradingview.com", class: "underline hover:text-gray-600", target: "_blank", rel: "noopener" %>
      </p>
    </div>
  <% else %>
    <div class="rounded-xl border border-amber-200 bg-amber-50 px-6 py-12 text-center text-amber-900">
      No candle data for the selected period.
    </div>
  <% end %>
</div>
