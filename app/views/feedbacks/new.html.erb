<div class="w-full max-w-xl mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Send feedback</h1>
  <p class="text-gray-600 mb-8">Tell us what works, what does not, or what you would like to see next.</p>

  <%= form_with model: @feedback, url: feedback_path, class: "space-y-6 rounded-xl border border-gray-200 bg-white p-6 shadow-sm" do |form| %>
    <% if @feedback.errors.any? %>
      <div class="rounded-lg bg-red-50 border border-red-200 px-4 py-3 text-red-800 text-sm">
        <p class="font-medium mb-1"><%= pluralize(@feedback.errors.count, "error") %> prevented your feedback from being sent:</p>
        <ul class="list-disc list-inside">
          <% @feedback.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= form.label :message, "Your message", class: "block text-sm font-medium text-gray-700 mb-2" %>
      <%= form.text_area :message, rows: 6, required: true,
            class: "w-full rounded-lg border border-gray-300 px-3 py-2 text-sm focus:border-blue-500 focus:ring-blue-500",
            placeholder: "Describe your experience or suggestion..." %>
    </div>

    <%= form.hidden_field :page_url, value: request.referer %>

    <div class="flex items-center gap-4">
      <%= form.submit "Send feedback", class: "rounded-lg bg-blue-600 px-4 py-2 text-sm font-medium text-white hover:bg-blue-700 cursor-pointer" %>
      <%= link_to "Cancel", root_path, class: "text-sm font-medium text-gray-600 hover:text-gray-900" %>
    </div>
  <% end %>
</div>
