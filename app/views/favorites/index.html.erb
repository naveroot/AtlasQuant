<div class="w-full max-w-5xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Favorites</h1>
    <p class="mt-2 text-gray-600">Your saved MOEX currency futures</p>
  </div>

  <% if @favorites.any? %>
    <div class="overflow-hidden rounded-xl border border-gray-200 bg-white shadow-sm">
      <table class="min-w-full divide-y divide-gray-200">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Ticker</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Name</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wide text-gray-500">Asset</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wide text-gray-500"></th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          <% @favorites.each do |instrument| %>
            <tr class="hover:bg-gray-50">
              <td class="px-6 py-4 font-mono text-sm font-medium text-gray-900"><%= instrument.secid %></td>
              <td class="px-6 py-4 text-sm text-gray-700"><%= instrument.shortname %></td>
              <td class="px-6 py-4 text-sm text-gray-500"><%= instrument.asset_code %></td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-3">
                  <%= link_to "Chart", instrument_path(instrument.secid), class: "text-sm font-medium text-blue-600 hover:text-blue-700" %>
                  <%= button_to "Remove", favorite_path(instrument.secid), method: :delete,
                        class: "text-sm font-medium text-red-600 hover:text-red-700 cursor-pointer" %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-xl border border-gray-200 bg-white px-6 py-12 text-center text-gray-600">
      No favorites yet.
      <%= link_to "Browse instruments", instruments_path, class: "ml-1 font-medium text-blue-600 hover:text-blue-700" %>
    </div>
  <% end %>
</div>
