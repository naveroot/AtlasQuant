<div class="w-full max-w-6xl mx-auto">
  <div class="mb-8">
    <h1 class="text-3xl font-bold text-gray-900">Favorites</h1>
    <p class="mt-2 text-gray-600">Your saved MOEX currency futures</p>
  </div>

  <% if @favorites.any? %>
    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
      <% @favorites.each do |favorite| %>
        <div class="rounded-xl border border-gray-200 bg-white p-5 shadow-sm">
          <div class="flex items-start justify-between gap-3">
            <div>
              <p class="font-mono text-lg font-semibold text-gray-900"><%= favorite.secid %></p>
              <p class="mt-1 text-sm text-gray-600"><%= favorite.shortname %></p>
            </div>
            <span class="rounded-full bg-blue-50 px-2.5 py-1 text-xs font-medium text-blue-700"><%= favorite.asset_code %></span>
          </div>
          <div class="mt-4 flex flex-wrap items-center gap-3">
            <%= link_to "View chart →",
                  instrument_path(favorite.secid),
                  class: "text-sm font-medium text-blue-600 hover:text-blue-700" %>
            <%= button_to "Remove",
                  instrument_favorite_path(favorite.secid),
                  method: :delete,
                  class: "rounded-lg border border-gray-300 px-3 py-1.5 text-sm font-medium text-gray-700 hover:bg-gray-50 cursor-pointer" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="rounded-xl border border-gray-200 bg-white px-6 py-12 text-center text-gray-600">
      <p>No favorites yet.</p>
      <p class="mt-2">
        Browse <%= link_to "instruments", instruments_path, class: "font-medium text-blue-600 hover:text-blue-700" %>
        and add them to your list.
      </p>
    </div>
  <% end %>
</div>
