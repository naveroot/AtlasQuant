<div class="w-full max-w-md mx-auto">
  <h1 class="text-3xl font-bold text-gray-900 mb-2">Sign in</h1>
  <p class="text-gray-600 mb-8">Welcome back to Atlas Quant.</p>

  <%= form_with url: session_path, scope: :session, class: "space-y-6" do |form| %>
    <div>
      <%= form.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.email_field :email, required: true, autofocus: true, autocomplete: "email",
            class: "w-full rounded-lg border border-gray-300 px-4 py-2 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" %>
    </div>

    <div>
      <%= form.label :password, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= form.password_field :password, required: true, autocomplete: "current-password",
            class: "w-full rounded-lg border border-gray-300 px-4 py-2 focus:border-blue-500 focus:ring-2 focus:ring-blue-200 outline-none" %>
    </div>

    <%= form.submit "Sign in", class: "w-full rounded-lg bg-blue-600 px-4 py-2 text-white font-medium hover:bg-blue-700 cursor-pointer" %>
  <% end %>

  <p class="mt-6 text-center text-sm text-gray-600">
    Don't have an account?
    <%= link_to "Sign up", new_registration_path, class: "text-blue-600 hover:text-blue-800 font-medium" %>
  </p>
</div>
